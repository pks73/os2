#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, req[100], head, i, total = 0;

    
    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter requests: ");
    for (i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    
    printf("\nServing order: %d", head);
    for (i = 0; i < n; i++) {
        total += abs(head - req[i]);
        printf(" -> %d", req[i]);
        head = req[i];               
    }

    
    printf("\nTotal head movement = %d\n", total);
    return 0;
}
